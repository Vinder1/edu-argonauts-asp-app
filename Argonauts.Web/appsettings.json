{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Valkey": "Information",
      "Microsoft.Valkey": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "GameDb": "Host=;Port=;Database=;Username=;Password=;SSL Mode=;",
    "valkey": "Host=;Port=;password=;ssl=",
    "HangfirePg": "Host=;Port=;Database=;Username=;Password=;SSL Mode=;",
    "HangfireRedis": "localhost:0000,password=,ssl=,abortConnect=false,syncTimeout=,connectTimeout=,defaultDatabase=,connectRetry="
  },
  "JwtSettings": {
    "Key": "",
    "Issuer": "AspNetAppApi",
    "Audience": "AspNetAppClients",
    "TokenLifetimeMinutes": 30,
    "RefreshTokenLifetimeDays": 7
  },
  "ObscenityFilter": {
    "BaseUrl": "http://localhost:5073"
  },

  "Resend": {
    "ApiKey": "",
    "FromEmail": "onboarding@resend.dev",
    "FromName": "Argonauts Team"
  },

  "Swagger": {
    "Definition": {
      "Id": "",
      "Name": "",
      "Description": ""
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "-",
                "rollingInterval": "Day",
                "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
                "fileSizeLimitBytes": 10485760,
                "rollOnFileSizeLimit": true,
                "retainedFileCountLimit": 30,
                "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ]
  }
}