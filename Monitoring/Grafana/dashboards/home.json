    "panels": [
      { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": ".NET Application Metrics", "type": "row" },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "drawStyle": "line" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "percent" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
        "id": 1,
        "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
        "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(process_cpu_seconds_total{instance=~\"$instance\"}[1m]) * 100", "legendFormat": "CPU {{instance}}", "refId": "A" }],
        "title": "CPU Usage",
        "type": "timeseries"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "drawStyle": "line" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "decmbytes" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
        "id": 2,
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
        "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "(process_resident_memory_bytes{instance=~\"$instance\"} or process_working_set_bytes{instance=~\"$instance\"}) / 1024 / 1024", "legendFormat": "Memory {{instance}}", "refId": "A" }],
        "title": "Memory Usage (RSS/WS)",
        "type": "timeseries"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "drawStyle": "line" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "reqps" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
        "id": 3,
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
        "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "sum(rate(http_requests_received_total{instance=~\"$instance\"}[1m])) by (code, method)", "legendFormat": "{{method}} {{code}}", "refId": "A" }],
        "title": "HTTP Request Rate",
        "type": "timeseries"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "drawStyle": "line" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "s" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
        "id": 4,
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
        "targets": [
          { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{instance=~\"$instance\"}[1m])) by (le))", "legendFormat": "p95", "refId": "A" },
          { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{instance=~\"$instance\"}[1m])) by (le))", "legendFormat": "p99", "refId": "B" }
        ],
        "title": "HTTP Request Latency",
        "type": "timeseries"
      },
      { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }, "id": 101, "title": "PostgreSQL Metrics", "type": "row" },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "drawStyle": "line" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
        "id": 5,
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
        "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "pg_stat_activity_count{datname=~\"$datname\"}", "legendFormat": "Connections {{datname}}", "refId": "A" }],
        "title": "Active Connections",
        "type": "timeseries"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "drawStyle": "line" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "decmbytes" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
        "id": 6,
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
        "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "pg_database_size_bytes{datname=~\"$datname\"} / 1024 / 1024", "legendFormat": "Size {{datname}}", "refId": "A" }],
        "title": "Database Size",
        "type": "timeseries"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 95 }] }, "unit": "percent" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
        "id": 7,
        "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto", "colorMode": "value", "graphMode": "area", "justifyMode": "auto" },
        "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "(sum(rate(pg_stat_database_blks_hit{datname=~\"$datname\"}[5m])) / (sum(rate(pg_stat_database_blks_hit{datname=~\"$datname\"}[5m])) + sum(rate(pg_stat_database_blks_read{datname=~\"$datname\"}[5m])))) * 100", "legendFormat": "Cache Hit %", "refId": "A" }],
        "title": "Cache Hit Ratio",
        "type": "stat"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "drawStyle": "line" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "ops" }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
        "id": 8,
        "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
        "targets": [
          { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(pg_stat_database_xact_commit{datname=~\"$datname\"}[1m])", "legendFormat": "Commits {{datname}}", "refId": "A" },
          { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(pg_stat_database_xact_rollback{datname=~\"$datname\"}[1m])", "legendFormat": "Rollbacks {{datname}}", "refId": "B" }
        ],
        "title": "Transactions (Commit vs Rollback)",
        "type": "timeseries"
      }
    ],
    "schemaVersion": 39,
    "style": "dark",
    "tags": ["dotnet", "postgres", "prometheus-net"],
    "templating": {
      "list": [
        { "name": "DS_PROMETHEUS", "type": "datasource", "query": "prometheus", "refresh": 1, "regex": "", "hide": 2, "current": { "text": "default", "value": "default" } },
        { "name": "instance", "type": "query", "query": "label_values(process_cpu_seconds_total, instance)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "refresh": 2, "regex": "", "current": { "text": "All", "value": "$__all" }, "includeAll": true, "multi": true, "label": ".NET Instance" },
        { "name": "datname", "type": "query", "query": "label_values(pg_stat_activity_count, datname)", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "refresh": 2, "regex": "/^(?!template|postgres).*$/", "current": { "text": "All", "value": "$__all" }, "includeAll": true, "multi": true, "label": "PostgreSQL Database" }
      ]
    },
